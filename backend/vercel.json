{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/index.js"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "ADMOB_API_KEY": "@admob_api_key",
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "crons": [
    {
      "path": "/api/cron/update-metrics",
      "schedule": "0 9,15,21 * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * 0"
    }
  ]
}
